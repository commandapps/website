# Copy to .env.local and fill in real values (or set these in Vercel for production).

# Stripe secret key (server-side only) — used by /api/checkout to create Checkout Sessions.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe publishable key (safe to expose; only needed if you add Stripe.js/Elements later).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
