# Copy to .env.local and fill in real values (or set these in Vercel for production).

# Stripe secret key (server-side only) — used by /api/checkout to create Checkout Sessions.
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe publishable key (safe to expose; only needed if you add Stripe.js/Elements later).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Resend API key — used by /api/contact to deliver form submissions via email.
# Sign up at https://resend.com, verify commandapplications.com, then create an API key.
RESEND_API_KEY=re_xxx

# Where contact form submissions are delivered (defaults to contact@commandapplications.com).
CONTACT_TO_EMAIL=contact@commandapplications.com

# Sender address — must use a domain verified in Resend (e.g. contact@commandapplications.com).
CONTACT_FROM_EMAIL=Command Applications <contact@commandapplications.com>

# Booking scheduler embed URL (Cal.com or Calendly). /contact renders this
# inline for the "Book a Strategy Call" CTA. The app already defaults to the
# live link below in code; only set this to override per-environment.
NEXT_PUBLIC_SCHEDULER_URL=https://cal.com/commandapplications

# Public site origin, used for canonical URLs, sitemap, and OG tags.
NEXT_PUBLIC_SITE_URL=https://commandapplications.com
